{
  "extends": "./tsconfig.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.test.tsx",
    "src/**/*.test.ts",
    "src/**/*.stories.tsx",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "eslint.config.mts",
    "vite.config.ts"
  ],
  "exclude": [
    "node_modules",
    "build",
    "docs-build"
  ],
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true
  }
}