{
  "extends": "./tsconfig.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.test.tsx",
    "src/**/*.test.ts",
    "src/**/*.stories.tsx",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "eslint.config.mts",
    "rollup.config.mjs",
    "jest.config.cjs",
    "babel.config.cjs"
  ],
  "exclude": [
    "node_modules",
    "build",
    "docs-build"
  ],
  "compilerOptions": {
    "noEmit": true,
    "allowJs": true
  }
}